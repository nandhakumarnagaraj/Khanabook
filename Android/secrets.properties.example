# ── WhatsApp / Meta Cloud API Credentials Template ────────────────────────────
# 1. Copy this file contents into 'local.properties' in the root project folder.
# 2. Replace the values below with your actual credentials.
# 3. ⚠️  NEVER commit real credentials to version control.

# Permanent Access Token (System User Token) from Meta Developer Console
# Generate at: https://developers.facebook.com/apps/ → WhatsApp → API Setup
META_ACCESS_TOKEN=YOUR_META_ACCESS_TOKEN_HERE

# The ID of the phone number sending the messages
WHATSAPP_PHONE_NUMBER_ID=YOUR_PHONE_NUMBER_ID_HERE

# The template name registered in Meta WhatsApp Manager (e.g., verification_otp)
WHATSAPP_OTP_TEMPLATE_NAME=verification_otp

# ── Android Release Signing ───────────────────────────────────────────────────
# Generate a keystore with: keytool -genkey -v -keystore release-key.jks
#   -alias <alias> -keyalg RSA -keysize 2048 -validity 10000
SIGNING_STORE_FILE=release-key.jks
SIGNING_STORE_PASSWORD=YOUR_KEYSTORE_PASSWORD
SIGNING_KEY_ALIAS=YOUR_KEY_ALIAS
SIGNING_KEY_PASSWORD=YOUR_KEY_PASSWORD
