<?xml version="1.0" encoding="utf-8"?>
<!--
  Data Extraction Rules (API 31+).
  Exclude database and shared preferences from cloud backup and device transfer.
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude the Room database and all SQLite auxiliary files -->
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
    </device-transfer>
</data-extraction-rules>
